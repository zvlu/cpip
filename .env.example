NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Optional legacy fallback (older projects):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: enables LLM-based semantic analysis. If omitted, app uses deterministic heuristics.
OPENAI_API_KEY=your-openai-api-key
SEMANTIC_ANALYSIS_MODEL=gpt-4o-mini
ALLOW_GUEST_MODE=false
ENABLE_PUBLIC_SIGNUP=false
PUBLIC_SIGNUP_RATE_LIMIT_WINDOW_MS=600000
PUBLIC_SIGNUP_RATE_LIMIT_MAX_REQUESTS=5

# Optional: secret for automated cron dispatch of weekly briefs.
# Send as x-brief-dispatch-secret header to POST /api/brief/dispatch with {"all_orgs": true}
BRIEF_DISPATCH_SECRET=your-brief-dispatch-secret

# Optional: secret for scrape worker dispatch jobs.
# Send as x-scrape-dispatch-secret header to POST /api/scrape/dispatch
SCRAPE_DISPATCH_SECRET=your-scrape-dispatch-secret

# Optional scraper tuning knobs
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_RETRY_BASE_DELAY_MS=600
SCRAPER_PROFILE_TIMEOUT_MS=30000
SCRAPER_SELECTOR_TIMEOUT_MS=15000
SCRAPER_DETAIL_TIMEOUT_MS=22000
SCRAPER_MAX_SCROLL_ATTEMPTS=10
SCRAPER_SCROLL_WAIT_MS=1600
SCRAPER_DETAIL_CONCURRENCY=4
SCRAPER_MIN_DETAIL_DELAY_MS=700
SCRAPER_MAX_DETAIL_JITTER_MS=1400

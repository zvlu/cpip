NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Optional legacy fallback (older projects):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: enables LLM-based semantic analysis. If omitted, app uses deterministic heuristics.
OPENAI_API_KEY=your-openai-api-key
SEMANTIC_ANALYSIS_MODEL=gpt-4o-mini
ALLOW_GUEST_MODE=false
ENABLE_PUBLIC_SIGNUP=false
PUBLIC_SIGNUP_RATE_LIMIT_WINDOW_MS=600000
PUBLIC_SIGNUP_RATE_LIMIT_MAX_REQUESTS=5
